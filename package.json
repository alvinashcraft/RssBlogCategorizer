{
  "name": "rss-blog-categorizer",
  "displayName": "%displayName%",
  "description": "%description%",
  "icon": "images/rssBlogIcon.png",
  "version": "3.10.0",
  "publisher": "alvinashcraft",
  "repository": {
    "type": "git",
    "url": "https://github.com/alvinashcraft/RssBlogCategorizer.git"
  },
  "homepage": "https://github.com/alvinashcraft/RssBlogCategorizer#readme",
  "bugs": {
    "url": "https://github.com/alvinashcraft/RssBlogCategorizer/issues"
  },
  "readme": "README.md",
  "license": "MIT",
  "keywords": [
    "rss",
    "blog",
    "wordpress",
    "content curation",
    "developer news"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "onView:rssBlogCategorizerView"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "rssBlogCategorizerView",
          "name": "%viewName%",
          "icon": "images/rssBlogIcon.png",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "rssBlogCategorizer.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "rssBlogCategorizer.exportMarkdown",
        "title": "%command.exportMarkdown%",
        "icon": "$(markdown)"
      },
      {
        "command": "rssBlogCategorizer.exportHtml",
        "title": "%command.exportHtml%",
        "icon": "$(globe)"
      },
      {
        "command": "rssBlogCategorizer.openPost",
        "title": "%command.openPost%"
      },
      {
        "command": "rssBlogCategorizer.addFeed",
        "title": "%command.addFeed%",
        "icon": "$(edit)"
      },
      {
        "command": "rssBlogCategorizer.setNewsblurCredentials",
        "title": "%command.setNewsblurCredentials%",
        "icon": "$(key)"
      },
      {
        "command": "rssBlogCategorizer.setSubmissionApiKey",
        "title": "%command.setSubmissionApiKey%",
        "icon": "$(key)"
      },
      {
        "command": "rssBlogCategorizer.setWordpressCredentials",
        "title": "%command.setWordpressCredentials%",
        "icon": "$(key)"
      },
      {
        "command": "rssBlogCategorizer.testWordpressConnection",
        "title": "%command.testWordpressConnection%",
        "icon": "$(plug)"
      },
      {
        "command": "rssBlogCategorizer.publishToWordpress",
        "title": "%command.publishToWordpress%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "rssBlogCategorizer.openWysiwygEditor",
        "title": "%command.openWysiwygEditor%",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rssBlogCategorizer.refresh",
          "when": "view == rssBlogCategorizerView",
          "group": "navigation"
        },
        {
          "command": "rssBlogCategorizer.addFeed",
          "when": "view == rssBlogCategorizerView",
          "group": "navigation"
        },
        {
          "command": "rssBlogCategorizer.exportMarkdown",
          "when": "view == rssBlogCategorizerView"
        },
        {
          "command": "rssBlogCategorizer.exportHtml",
          "when": "view == rssBlogCategorizerView"
        },
        {
          "command": "rssBlogCategorizer.setNewsblurCredentials",
          "when": "view == rssBlogCategorizerView"
        },
        {
          "command": "rssBlogCategorizer.setSubmissionApiKey",
          "when": "view == rssBlogCategorizerView"
        },
        {
          "command": "rssBlogCategorizer.setWordpressCredentials",
          "when": "view == rssBlogCategorizerView"
        },
        {
          "command": "rssBlogCategorizer.testWordpressConnection",
          "when": "view == rssBlogCategorizerView"
        }
      ],
      "editor/title": [
        {
          "command": "rssBlogCategorizer.openWysiwygEditor",
          "when": "resourceExtname == .html || resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation"
        },
        {
          "command": "rssBlogCategorizer.publishToWordpress",
          "when": "resourceExtname == .html && resourcePath =~ /.*Dew Drop.*/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "rssBlogCategorizer.feedUrl": {
          "type": "string",
          "default": "https://dev.to/feed",
          "description": "%config.feedUrl.description%"
        },
        "rssBlogCategorizer.recordCount": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 500,
          "description": "%config.recordCount.description%"
        },
        "rssBlogCategorizer.minimumDateTime": {
          "type": "string",
          "default": "",
          "description": "%config.minimumDateTime.description%"
        },
        "rssBlogCategorizer.enablePostFilteringBuffer": {
          "type": "boolean",
          "default": true,
          "description": "%config.enablePostFilteringBuffer.description%"
        },
        "rssBlogCategorizer.postFilteringBufferMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 60,
          "description": "%config.postFilteringBufferMinutes.description%"
        },
        "rssBlogCategorizer.enableAutoRefresh": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableAutoRefresh.description%"
        },
        "rssBlogCategorizer.refreshInterval": {
          "type": "number",
          "default": 30,
          "description": "%config.refreshInterval.description%"
        },
        "rssBlogCategorizer.newsblurUsername": {
          "type": "string",
          "default": "",
          "description": "%config.newsblurUsername.description%"
        },
        "rssBlogCategorizer.useNewsblurApi": {
          "type": "boolean",
          "default": false,
          "description": "%config.useNewsblurApi.description%"
        },
        "rssBlogCategorizer.enableSubmissionApiSource": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableSubmissionApiSource.description%"
        },
        "rssBlogCategorizer.submissionApiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "%config.submissionApiBaseUrl.description%"
        },
        "rssBlogCategorizer.wordpressBlogUrl": {
          "type": "string",
          "default": "",
          "description": "%config.wordpressBlogUrl.description%"
        },
        "rssBlogCategorizer.wordpressUsername": {
          "type": "string",
          "default": "",
          "description": "%config.wordpressUsername.description%"
        },
        "rssBlogCategorizer.wordpressCategories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Daily Links",
            "Development"
          ],
          "description": "%config.wordpressCategories.description%"
        },
        "rssBlogCategorizer.openLinksInNewTab": {
          "type": "boolean",
          "default": false,
          "description": "%config.openLinksInNewTab.description%"
        },
        "rssBlogCategorizer.enableDometrainSection": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableDometrainSection.description%"
        },
        "rssBlogCategorizer.dometrainLastCourseId": {
          "type": "string",
          "default": "",
          "description": "%config.dometrainLastCourseId.description%"
        },
        "rssBlogCategorizer.openBlogAfterPublish": {
          "type": "boolean",
          "default": true,
          "description": "%config.openBlogAfterPublish.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:basic": "npm run compile-tests && mocha --no-config out/test/basic/**/*.test.js",
    "test:unit": "mocha --require ts-node/register src/test/unit/**/*.test.ts",
    "test:unit:compiled": "mocha out/test/unit/**/*.test.js"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/chai-as-promised": "^7.1.8",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "16.x",
    "@types/sinon": "^17.0.2",
    "@types/sinon-chai": "^3.2.12",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "@vscode/test-electron": "^2.3.8",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "copy-webpack-plugin": "^13.0.1",
    "glob": "^10.3.10",
    "markdownlint-cli": "^0.47.0",
    "minimatch": "^5.1.6",
    "mocha": "^10.2.0",
    "sinon": "^17.0.1",
    "sinon-chai": "^3.7.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "fast-xml-parser": "^4.3.2",
    "tinymce": "^8.1.2"
  }
}
